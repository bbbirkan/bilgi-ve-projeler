# LLM API Keys — Şablon
# Kopyala: cp .llm_keys.env.example .llm_keys.env
# Gerçek key'leri .llm_keys.env'e yaz (.gitignore'da olmalı)
# Yükle: source /root/bilgi-ve-projeler/.llm_keys.env

# xAI Grok API — console.x.ai → API Keys → Create API Key
XAI_API_KEY=

# OpenRouter (çoklu model gateway) — openrouter.ai/keys → Create Key
OPENROUTER_KEY=

# Anthropic Claude API — console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# OpenAI API — platform.openai.com/api-keys → Create new secret key
OPENAI_API_KEY=

# Groq (hızlı inference, Whisper) — console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# MiniMax (TTS + LLM) — platform.minimax.io → Account → API Keys
MINIMAX_API_KEY=

# Telegram Bot — Telegram'da @BotFather → /newbot → token verir
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID — @userinfobot'a mesaj at veya getUpdates API'den al
TELEGRAM_CHAT_ID=