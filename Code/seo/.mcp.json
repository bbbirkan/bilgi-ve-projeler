
{
  "mcpServers": {
    "ahrefs": {
      "type": "http",
      "url": "https://api.ahrefs.com/mcp/mcp"
    },
    "semrush": {
      "type": "http",
      "url": "https://mcp.semrush.com/v1/mcp"
    },
    "firecrawl": {
      "type": "http",
      "url": "https://mcp.firecrawl.dev/{YOUR-FIRECRAWL-API-KEY}/v2/mcp"
    },
    "dataforseo": {
      "type": "stdio",
      "command": "npx",
      "args": ["dataforseo-mcp-server"],
      "env": {
        "DATAFORSEO_USERNAME": "{YOUR-DATAFORSEO-USERNAME}",
        "DATAFORSEO_PASSWORD": "{YOUR-API-PASSWORD}"
      }
    }
  }
}
